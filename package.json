{
  "name": "open-wiki-studio",
  "version": "0.1.1",
  "description": "Local desktop app (Windows, macOS, Linux) that turns your documents into a queryable Markdown wiki. An on-device AI agent reads your files, writes linked OKF concepts, and answers chat questions with citations back to the source concepts. Everything stays local except the LLM calls you connect.",
  "type": "module",
  "license": "MIT",
  "main": "./out/main/index.js",
  "author": {
    "name": "Panzenbaby",
    "url": "https://github.com/Panzenbaby"
  },
  "homepage": "https://github.com/Panzenbaby/open-wiki-studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/Panzenbaby/open-wiki-studio.git"
  },
  "bugs": {
    "url": "https://github.com/Panzenbaby/open-wiki-studio/issues"
  },
  "keywords": [
    "wiki",
    "knowledge-base",
    "knowledge-graph",
    "llm",
    "ai",
    "rag",
    "markdown",
    "okf",
    "open-knowledge-format",
    "electron",
    "desktop",
    "local-first",
    "pi-coding-agent"
  ],
  "engines": {
    "node": ">=22.19.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run package:mac && npm run package:win && npm run package:linux",
    "release:patch": "npm version patch -m \"chore(release): %s\"",
    "release:minor": "npm version minor -m \"chore(release): %s\"",
    "release:major": "npm version major -m \"chore(release): %s\"",
    "package:mac": "electron-vite build && npm run sync-ext-deps && electron-builder --mac --arm64 --x64",
    "package:win": "electron-vite build && npm run sync-ext-deps && electron-builder --win --arm64 --x64",
    "package:linux": "electron-vite build && npm run sync-ext-deps && electron-builder --linux --arm64 --x64",
    "sync-ext-deps": "node scripts/sync-ext-deps.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3",
    "electron-updater": "^6.8.9",
    "jotai": "^2.10.0",
    "lucide-react": "^1.23.0",
    "pi-okf-wiki": "github:Panzenbaby/pi-okf-wiki#0.2.0-alpha01",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typebox": "*",
    "typescript": "^5.5.4",
    "vite": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "de.panzenlabs.openwikistudio",
    "productName": "Open Wiki Studio",
    "copyright": "Copyright © 2026 Panzenbaby",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Panzenbaby",
      "repo": "open-wiki-studio",
      "releaseType": "release"
    },
    "icon": "build/icon",
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/pi-okf-wiki"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icons/icon.png"
      },
      {
        "from": "node_modules/pi-okf-wiki",
        "to": "pi-okf-wiki",
        "filter": [
          "src/**",
          "node_modules/**",
          "package.json",
          "LICENSE"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "linux": {
      "target": "AppImage",
      "category": "Office",
      "icon": "build/icon.png"
    }
  },
  "allowScripts": {
    "electron@31.7.7": true
  }
}
